{
  "mcpServers": {
    "handoff": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.handoff.server"]
    },
    "email_processor": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.email_processor.server"]
    },
    "taskmanager": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.taskmanager.server"]
    },
    "knowledge_base": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.knowledge_base.server"]
    },
    "session_memory": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.session_memory.server"],
      "env": {
        "SESSION_DB_PATH": "Library/System/Hermes/session.db"
      }
    }
  }
}
