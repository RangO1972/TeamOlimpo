{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "hermes",
  "mcp": {
    "handoff": {
      "type": "local",
      "command": ["uv", "run", "python", "-m", "tools.handoff.server"],
      "enabled": true
    },
    "email_processor": {
      "type": "local",
      "command": ["uv", "run", "python", "-m", "tools.email_processor.server"],
      "enabled": true
    },
    "taskmanager": {
      "type": "local",
      "command": ["uv", "run", "python", "-m", "tools.taskmanager.server"],
      "enabled": true
    },
    "knowledge_base": {
      "type": "local",
      "command": ["uv", "run", "python", "-m", "tools.knowledge_base.server"],
      "enabled": true
    }
  }
}
